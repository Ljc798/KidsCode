generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  phone     String?  @unique
  account   String?  @unique
  password  String
  role      UserRole
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  student Student?
  parent  Parent?
}

model Student {
  id        String   @id @default(uuid())
  userId    String   @unique
  nickname  String
  age       Int
  className String?
  pointsBalance Int @default(0)
  starCoinsBalance Int @default(0)
  dailyPointsDate String?
  dailyPointsEarned Int @default(0)
  exercisePointsDate String?
  exercisePointsEarned Int @default(0)
  xp Int @default(0)
  concept Concept @default(BRANCH)
  petName String @default("小码兽")
  petSpecies String @default("云朵龙")
  petXp Int @default(0)
  petMeat Int @default(0)
  petMood Int @default(100)
  petEnergy Int @default(100)
  petEnergyRefreshedAt DateTime @default(now()) @db.Timestamptz(3)
  gamesCompleted Int @default(0)
  codeSubmissions Int @default(0)
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id])

  parentId String?
  parent   Parent? @relation(fields: [parentId], references: [id])

  gameSessions GameSession[]
  progress     LearningProgress[]
  activities   StudentActivity[]
  exerciseSubmissions ExerciseSubmission[]
  projects     StudentProject[]
}

model Parent {
  id        String   @id @default(uuid())
  userId    String   @unique
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id])

  children Student[]
}

model Course {
  id          String   @id @default(uuid())
  title       String
  description String?
  createdAt   DateTime @default(now()) @db.Timestamptz(3)

  games Game[]
}

model Game {
  id        String   @id @default(uuid())
  title     String
  courseId  String
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  course Course @relation(fields: [courseId], references: [id])

  sessions GameSession[]
}

model GameSession {
  id        String   @id @default(uuid())
  studentId String
  gameId    String
  score     Int
  playedAt  DateTime @default(now()) @db.Timestamptz(3)

  student Student @relation(fields: [studentId], references: [id])
  game    Game    @relation(fields: [gameId], references: [id])
}

model LearningProgress {
  id        String   @id @default(uuid())
  studentId String
  courseId  String
  progress  Int
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  student Student @relation(fields: [studentId], references: [id])
}

model MiniGame {
  slug      String   @id
  title     String
  emoji     String
  blurb     String
  requires  Concept
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
}

model KnowledgeArticle {
  slug        String            @id
  language    KnowledgeLanguage
  title       String
  summary     String?
  contentMd   String
  order       Int               @default(0)
  isPublished Boolean           @default(true)
  createdAt   DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime          @updatedAt @db.Timestamptz(3)
}

enum UserRole {
  STUDENT
  PARENT
  ADMIN
}

enum Concept {
  BRANCH
  LOOP
}

enum KnowledgeLanguage {
  CPP
}

enum StudentActivityKind {
  MINIGAME_PLAY
  CODE_SUBMIT
  POINTS_AWARD
}

model StudentActivity {
  id             String              @id @default(uuid())
  studentId      String
  kind           StudentActivityKind
  miniGameSlug   String?
  ok             Boolean?
  pointsRequested Int?
  pointsAdded    Int?
  code           String?
  meta           Json?
  createdAt      DateTime            @default(now()) @db.Timestamptz(3)

  student Student @relation(fields: [studentId], references: [id])

  @@index([studentId, createdAt])
  @@index([kind, createdAt])
  @@index([miniGameSlug, createdAt])
}

model ExerciseBank {
  id            String   @id @default(uuid())
  slug          String   @unique
  title         String
  summary       String?
  imageUrl      String?
  level         Int
  multipleChoice Json
  codingTasks    Json?
  codingTitle   String
  codingPrompt  String
  codingPlaceholder String?
  isPublished   Boolean  @default(true)
  createdAt     DateTime @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @db.Timestamptz(3)

  submissions ExerciseSubmission[]

  @@index([level, isPublished])
  @@index([createdAt])
}

model ExerciseSubmission {
  id                  String   @id @default(uuid())
  exerciseBankId      String
  studentId           String
  multipleChoiceAnswers Json
  multipleChoiceFeedback Json?
  multipleChoiceScore Int
  multipleChoiceTotal Int
  multipleChoicePoints Int @default(0)
  codingPoints        Int @default(0)
  codingMaxPoints     Int @default(0)
  totalPoints         Int @default(0)
  totalMaxPoints      Int @default(100)
  codingAnswer        String
  codingAnswers       Json?
  codingStatus        ExerciseCodingStatus @default(PENDING)
  codingIsCorrect     Boolean?
  teacherFeedback     String?
  createdAt           DateTime @default(now()) @db.Timestamptz(3)
  reviewedAt          DateTime? @db.Timestamptz(3)

  exerciseBank ExerciseBank @relation(fields: [exerciseBankId], references: [id])
  student      Student      @relation(fields: [studentId], references: [id])

  @@index([studentId, createdAt])
  @@index([exerciseBankId, createdAt])
  @@index([codingStatus, createdAt])
}

enum ExerciseCodingStatus {
  PENDING
  REVIEWED
}

enum StudentProjectKind {
  SCRATCH
  OTHER
  CPP
}

enum StudentProjectCategory {
  PERSONAL
  CLASSROOM
}

enum StudentProjectReviewStatus {
  NONE
  PENDING
  REVIEWED
}

model StudentProject {
  id        String             @id @default(uuid())
  studentId String
  kind      StudentProjectKind
  category  StudentProjectCategory @default(PERSONAL)
  title     String
  uploaderName String?
  weekNumber Int?
  ideaNote  String?
  commonMistakes String?
  content   String?
  fileName  String?
  mimeType  String?
  size      Int?
  bucket    String?
  objectKey String?
  storageProvider String?
  reviewStatus StudentProjectReviewStatus @default(NONE)
  teacherComment String?
  reviewedAt DateTime? @db.Timestamptz(3)
  createdAt DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt DateTime           @updatedAt @db.Timestamptz(3)

  student Student @relation(fields: [studentId], references: [id])

  @@index([studentId, updatedAt])
  @@index([kind, createdAt])
}
